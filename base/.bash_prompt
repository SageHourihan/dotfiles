# 80s Amber Terminal Prompt
# Warm amber glow, single-line format
# HH:MM  user · host  dir  branch [status]  Xs ❯

if [[ $COLORTERM = gnome-* && $TERM = xterm ]] && infocmp gnome-256color >/dev/null 2>&1; then
	export TERM='gnome-256color';
elif infocmp xterm-256color >/dev/null 2>&1; then
	export TERM='xterm-256color';
fi;

prompt_git() {
	local s='';
	local branchName='';

	if [ $(git rev-parse --is-inside-work-tree &>/dev/null; echo "${?}") == '0' ]; then

		if [ "$(git rev-parse --is-inside-git-dir 2> /dev/null)" == 'false' ]; then

			git update-index --really-refresh -q &>/dev/null;

			# staged changes
			if ! $(git diff --quiet --ignore-submodules --cached); then
				s+='+';
			fi;

			# unstaged changes
			if ! $(git diff-files --quiet --ignore-submodules --); then
				s+='!';
			fi;

			# untracked files
			if [ -n "$(git ls-files --others --exclude-standard)" ]; then
				s+='?';
			fi;

			# stashed files
			if $(git rev-parse --verify refs/stash &>/dev/null); then
				s+='$';
			fi;

		fi;

		branchName="$(git symbolic-ref --quiet --short HEAD 2> /dev/null || \
			git rev-parse --short HEAD 2> /dev/null || \
			echo '(unknown)')";

		[ -n "${s}" ] && s=" [${s}]";
		echo -e "${1}${branchName}${2}${s}";
	else
		return;
	fi;
}

if tput setaf 1 &> /dev/null; then
	tput sgr0;
	bold=$(tput bold);
	reset=$(tput sgr0);
	# Amber palette — warm 80s terminal glow
	amber_bright=$(tput setaf 214);  # bright orange-amber (username, ❯)
	amber=$(tput setaf 178);         # golden amber (directory)
	amber_mid=$(tput setaf 136);     # mid amber (git branch, clock)
	amber_dim=$(tput setaf 94);      # dark amber (separators, duration)
	amber_warn=$(tput setaf 166);    # red-amber (errors, root, SSH)
else
	bold='';
	reset="\e[0m";
	amber_bright="\e[38;5;214m";
	amber="\e[38;5;178m";
	amber_mid="\e[38;5;136m";
	amber_dim="\e[38;5;94m";
	amber_warn="\e[38;5;166m";
fi;

# Root gets warning tint
if [[ "${USER}" == "root" ]]; then
	userStyle="${bold}${amber_warn}";
else
	userStyle="${bold}${amber_bright}";
fi;

# SSH gets warning tint on hostname
if [[ "${SSH_TTY}" ]]; then
	hostStyle="${bold}${amber_warn}";
else
	hostStyle="${amber_dim}";
fi;

# --- Command timer ---
# Guard flag prevents the trap from firing inside PROMPT_COMMAND itself.
_prompt_running=0;
trap '[[ $_prompt_running -eq 0 ]] && _cmd_start=$SECONDS' DEBUG;

_set_prompt() {
	local exit_code=$?;
	_prompt_running=1;

	# Duration: only show if command took 3+ seconds
	local duration_str='';
	if [[ -n $_cmd_start ]]; then
		local elapsed=$(( SECONDS - _cmd_start ));
		if [[ $elapsed -ge 3 ]]; then
			duration_str=" \[${amber_dim}\] ${elapsed}s";
		fi;
		unset _cmd_start;
	fi;

	# Prompt char: red-amber on failure, bright amber on success
	local prompt_color;
	if [[ $exit_code -ne 0 ]]; then
		prompt_color="${amber_warn}";
	else
		prompt_color="${amber_bright}";
	fi;

	# Build PS1
	PS1="\[\033]0;\W\007\]";
	PS1+="\[${amber_mid}\]\@  ";                                                        # clock 12hr HH:MM am/pm
	PS1+="\[${userStyle}\]\u";                                                          # username
	PS1+="\[${amber_dim}\] · ";                                                         # separator
	PS1+="\[${hostStyle}\]\h";                                                          # hostname
	PS1+="\[${amber_dim}\]  ";                                                         # separator
	PS1+="\[${amber}\]\W";                                                              # current dir
	PS1+="\$(prompt_git \"\[${amber_dim}\]  \[${amber_mid}\]\" \"\[${amber_mid}\]\")"; # git
	PS1+="${duration_str}";                                                             # duration
	PS1+=" \[${bold}${prompt_color}\]❯\[${reset}\] ";                                  # prompt char

	_prompt_running=0;
};

PROMPT_COMMAND='_set_prompt';

PS2="\[${amber_mid}\]❯ \[${reset}\]";
export PS2;
